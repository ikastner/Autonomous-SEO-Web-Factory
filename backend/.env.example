# ==========================================
# AUTONOMOUS SEO WEB FACTORY - CONFIGURATION
# ==========================================

# 1. Cœur d'Intelligence (LLM)
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENAI_API_BASE="https://openrouter.ai/api/v1"
OPENAI_MODEL="gpt-4o-mini"

# 2. L'Arme Secrète du Debugging : LangSmith (Fortement Recommandé !)
# LangSmith te permet de visualiser ton graphe LangGraph en temps réel.
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
LANGCHAIN_PROJECT="SEO-Factory-Dev"

# 3. Configuration de l'API (FastAPI)
ENVIRONMENT="development"
PORT=8000
DEBUG="true"

# 4. Configuration Crawl4AI (si vous utilisez Crawl4AI)
CRAWL4AI_HEADLESS="true"           # Mode headless pour serveur
CRAWL4AI_TIMEOUT="30"              # Timeout en secondes
CRAWL4AI_WAIT_TIME="2"             # Temps d'attente après chargement
 
# 5. Sécurité (pour production)
API_RATE_LIMIT="100"               # Requêtes par minute
API_KEY_REQUIRED="false"           # Auth simple si besoin
 
# 6. Optimisation LLM
OPENAI_MODEL="gpt-4o-mini"         # Modèle par défaut (moins cher)
LLM_TEMPERATURE="0.2"              # Température pour cohérence